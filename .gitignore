# ================================
# GoldPilot 项目 .gitignore
# 最后更新：2026-05-16
# ================================

# Claude Code
.claude/

# AI开发计划（内部文档）
ai开发计划/

# ================================
# Node.js / NPM
# ================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ================================
# 构建输出
# ================================
dist/
build/
*.local
out/

# ================================
# 环境变量（重要！不要提交）
# ================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ================================
# 日志文件
# ================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ================================
# 编辑器和IDE
# ================================
# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
!.vscode/tasks.json
!.vscode/launch.json

# JetBrains IDEs
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ================================
# 操作系统
# ================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ================================
# 测试和覆盖率
# ================================
coverage/
*.lcov
.nyc_output/
junit.xml

# ================================
# PM2
# ================================
.pm2/
pids/
*.pid
*.seed
*.pid.lock

# ================================
# 临时文件
# ================================
*.tmp
*.temp
.cache/
.parcel-cache/
.vite/

# ================================
# 数据库
# ================================
*.db
*.sqlite
*.sqlite3
data/

# ================================
# 备份文件
# ================================
*.bak
*.backup
*.old

# ================================
# 其他
# ================================
